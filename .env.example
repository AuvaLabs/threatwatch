# ThreatWatch Configuration
# Copy this file to .env and customize as needed

# Site domain (used in RSS feed links)
SITE_DOMAIN=localhost:8098

# How many days of articles to keep (default: 7)
FEED_CUTOFF_DAYS=7

# HTTP server port
PORT=8098

# Optional: NewsAPI.org — security news feed (free tier: 100 req/day)
# NEWSAPI_KEY=your-newsapi-key
# NEWSAPI_INTERVAL=1800   # seconds between calls (default 1800 = 30 min)

# Optional: AI-powered briefing (works with any OpenAI-compatible provider)
# LLM_API_KEY=your-api-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_PROVIDER=auto
# Briefing prompt is too large for 70B free-tier TPM (6K cap per request);
# default the briefing only to the lighter 8B model. Set to LLM_MODEL to
# override once you're on a paid tier with bigger per-call headroom.
# BRIEFING_MODEL=llama-3.1-8b-instant

# Optional: Featherless.ai — paid OpenAI-compatible provider used ONLY for the
# daily global briefing (32K context > Groq free-tier 6K TPM). On any failure
# the briefing falls back to Groq + BRIEFING_MODEL. The token is shared across
# multiple projects, so ThreatWatch only invokes Featherless once per pipeline
# run (the briefing). Do NOT add this key to LLM_API_KEYS — different base URL.
# FEATHERLESS_API_KEY=rc_xxxxxxxxxxxx
# FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
# FEATHERLESS_MODEL=openai/gpt-oss-120b
# FEATHERLESS_TIMEOUT=60
#
# Model selection note: openai/gpt-oss-120b (concurrency_cost=2) is the
# recommended primary for plans up to feather_pro_plus (4 units). It's
# OpenAI's open-source 120B model, strong at structured JSON output and
# multi-document synthesis. Larger models like deepseek-ai/DeepSeek-V3.2
# or moonshotai/Kimi-K2-Instruct cost 4 units per request — they only fit
# if your plan budget is wholly available; otherwise every call 429s with
# "concurrency_limit_exceeded".

# Optional: Secondary briefing provider — any authenticated OpenAI-compatible
# API used as the 2nd-tier briefing fallback (primary FEATHERLESS → this →
# base Groq+8B). A distinct provider here (e.g. Cerebras) gives the flagship
# briefing a third independent path. Send the key as a bearer; leave BASE_URL
# blank to disable the tier. Example (Cerebras free tier):
# BRIEFING_FALLBACK_BASE_URL=https://api.cerebras.ai/v1
# BRIEFING_FALLBACK_API_KEY=csk-...
# BRIEFING_FALLBACK_MODEL=gpt-oss-120b
# BRIEFING_FALLBACK_TIMEOUT=60
#
# UFW: bridge host firewall must allow ThreatWatch's docker subnet to :8400.
# Example: sudo ufw allow from 172.21.0.0/16 to any port 8400 proto tcp

# Optional: Telegram channel — KEV per-CVE alerts + briefing dispatcher
# TELEGRAM_BOT_TOKEN=123456:AA-...
# TELEGRAM_CHAT_ID=@your_channel
# TELEGRAM_MIN_LEVEL=CRITICAL              # CRITICAL | ELEVATED | MODERATE | …
# TELEGRAM_COOLDOWN_HOURS=6
# TELEGRAM_KEV_MAX_AGE_DAYS=14             # suppress KEV alerts older than N days
                                           # (0 disables the filter)

# Optional: Webhook alerts (Slack or generic)
# WEBHOOK_URL=https://hooks.slack.com/services/...
# WEBHOOK_MIN_CONF=80

# Optional: Server-side watchlist persistence
# WATCHLIST_WRITE_ENABLED=true
# WATCHLIST_TOKEN=your-secret-token

# Optional: CORS — restrict /api/health and /api/watchlist to a specific origin
# CORS_ORIGIN=https://threatwatch.auvalabs.com
